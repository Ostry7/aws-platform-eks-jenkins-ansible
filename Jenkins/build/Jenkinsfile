pipeline {
    agent any // Specifies where the pipeline runs (e.g., any available node)

    stages {
        stage('Build') {
            steps {
                echo '[BUILD STAGE] Building the application...'
            }
        }

        stage('Test') {
            steps {
                echo '[BUILD STAGE] Running unit tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo '[BUILD STAGE] Deploying to production...'
            }
        }
    }
}