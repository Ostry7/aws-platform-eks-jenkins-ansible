pipeline {
    agent { label 'infra' }

    stages {
        stage('Build') {
            steps {
                echo '[INFRA STAGE] Building the application...'
            }
        }

        stage('Test') {
            steps {
                echo '[INFRA STAGE] Running unit tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo '[INFRA STAGE] Deploying to production...'
            }
        }
    }
}