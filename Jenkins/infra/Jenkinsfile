pipeline {
    agent { label 'infra' }

    stages {
        stage('Checkout Git repo') {
            steps {
                checkout scmGit(
                    branches: [[name: '*']],
                    extensions: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/Ostry7/aws-platform-eks-jenkins-ansible'
                    ]]
)
            }
        }

        stage('Test') {
            steps {
                echo '[INFRA STAGE] Running unit tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo '[INFRA STAGE] Deploying to production...'
            }
        }
    }
}
